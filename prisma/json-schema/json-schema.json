{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "User": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "role": {
          "type": "string",
          "default": "CUSTOMER",
          "enum": [
            "ADMIN",
            "CUSTOMER"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "username",
        "password",
        "updatedAt"
      ]
    },
    "Manufacturer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "logoUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "website": {
          "type": [
            "string",
            "null"
          ]
        },
        "products": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Product"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "slug",
        "updatedAt"
      ]
    },
    "Category": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "imageUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "sortOrder": {
          "type": "integer",
          "default": 0
        },
        "isActive": {
          "type": "boolean",
          "default": true
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ]
        },
        "parent": {
          "anyOf": [
            {
              "$ref": "#/definitions/Category"
            },
            {
              "type": "null"
            }
          ]
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Category"
          }
        },
        "products": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Product"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "slug",
        "updatedAt"
      ]
    },
    "Product": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "price": {
          "type": "string"
        },
        "comparePrice": {
          "type": [
            "number",
            "null"
          ]
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "sku": {
          "type": [
            "string",
            "null"
          ]
        },
        "stock": {
          "type": "integer",
          "default": 0
        },
        "origin": {
          "type": [
            "string",
            "null"
          ]
        },
        "imageUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "isActive": {
          "type": "boolean",
          "default": true
        },
        "isFeatured": {
          "type": "boolean",
          "default": false
        },
        "categoryId": {
          "type": "string"
        },
        "category": {
          "$ref": "#/definitions/Category"
        },
        "manufacturerId": {
          "type": [
            "string",
            "null"
          ]
        },
        "manufacturer": {
          "anyOf": [
            {
              "$ref": "#/definitions/Manufacturer"
            },
            {
              "type": "null"
            }
          ]
        },
        "images": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProductImage"
          }
        },
        "reviews": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Review"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "slug",
        "price",
        "categoryId",
        "updatedAt"
      ]
    },
    "ProductImage": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "alt": {
          "type": [
            "string",
            "null"
          ]
        },
        "sortOrder": {
          "type": "integer",
          "default": 0
        },
        "isPrimary": {
          "type": "boolean",
          "default": false
        },
        "productId": {
          "type": "string"
        },
        "product": {
          "$ref": "#/definitions/Product"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "url",
        "productId"
      ]
    },
    "Review": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "authorName": {
          "type": "string"
        },
        "rating": {
          "type": "integer"
        },
        "comment": {
          "type": [
            "string",
            "null"
          ]
        },
        "isApproved": {
          "type": "boolean",
          "default": false
        },
        "productId": {
          "type": [
            "string",
            "null"
          ]
        },
        "product": {
          "anyOf": [
            {
              "$ref": "#/definitions/Product"
            },
            {
              "type": "null"
            }
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "authorName",
        "rating",
        "updatedAt"
      ]
    }
  },
  "type": "object",
  "properties": {
    "user": {
      "$ref": "#/definitions/User"
    },
    "manufacturer": {
      "$ref": "#/definitions/Manufacturer"
    },
    "category": {
      "$ref": "#/definitions/Category"
    },
    "product": {
      "$ref": "#/definitions/Product"
    },
    "productImage": {
      "$ref": "#/definitions/ProductImage"
    },
    "review": {
      "$ref": "#/definitions/Review"
    }
  }
}