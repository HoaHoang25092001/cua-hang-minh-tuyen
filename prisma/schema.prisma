// Prisma Schema – Cửa Hàng Minh Tuyến
// Docs: https://pris.ly/d/prisma-schema

// ── Generator: Prisma Client (Prisma 7 format) ───────────────────────────────
generator client {
  provider = "prisma-client-js"
}

// ── Generator: JSON Schema (cho next-admin) ───────────────────────────────────
generator jsonSchema {
  provider                 = "prisma-json-schema-generator"
  includeRequiredFields    = "true"
  keepRelationScalarFields = "true"
  output                   = "./json-schema"
}

// ── Datasource: Neon Postgres (URL managed by prisma.config.ts in Prisma 7) ──
datasource db {
  provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

// Phân quyền người dùng
enum Role {
  ADMIN
  CUSTOMER
}

// ── Models ────────────────────────────────────────────────────────────────────

// Người dùng hệ thống (Admin quản lý, Customer xem hàng)
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Nhà sản xuất / Thương hiệu
model Manufacturer {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  logoUrl     String?
  website     String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("manufacturers")
}

// Loại hàng (cấp 1): Ống nước, Điện dân dụng, Đồ biển, Đồ nuôi tôm cá, v.v.
model Category {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  imageUrl    String?
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  // Hỗ trợ danh mục con (cấp 2)
  parentId    String?
  parent      Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]  @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("categories")
}

// Sản phẩm
model Product {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  description    String?        // Rich text HTML (tiptap)
  price          String         // Giá bán – có thể là số hoặc văn bản (VD: "Liên hệ")
  comparePrice   Float?         // Giá gốc để hiển thị giảm giá (số thực)
  unit           String?        // Đơn vị: cái, bộ, mét, cuộn, ...
  sku            String?        @unique
  stock          Int            @default(0)
  origin         String?        // Xuất xứ sản phẩm (VD: Việt Nam, Nhật Bản)
  imageUrl       String?        // Ảnh chính sản phẩm
  isActive       Boolean        @default(true)
  isFeatured     Boolean        @default(false)
  categoryId     String
  category       Category       @relation(fields: [categoryId], references: [id])
  manufacturerId String?
  manufacturer   Manufacturer?  @relation(fields: [manufacturerId], references: [id])
  images         ProductImage[]
  reviews        Review[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("products")
}

// Ảnh sản phẩm
model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("product_images")
}

// Đánh giá của khách hàng (không cần đăng nhập)
// productId = null → đánh giá chung về cửa hàng
// productId có giá trị → đánh giá sản phẩm cụ thể (legacy)
model Review {
  id         String   @id @default(cuid())
  authorName String   // Tên người đánh giá
  rating     Int      // 1–5 sao
  comment    String?
  isApproved Boolean  @default(false) // Admin duyệt trước khi hiển thị
  productId  String?  // Nullable – null = đánh giá chung cửa hàng
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("reviews")
}
